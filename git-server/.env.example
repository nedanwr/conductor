# Copy to .env for local development. Never commit real secrets — SSH host keys,
# TLS material, and the PG DSN come from env/mounts, not the repo (SPEC §4.11).

# Postgres (consumed by docker-compose.yml).
POSTGRES_USER=gitserver
POSTGRES_PASSWORD=gitserver
POSTGRES_DB=gitserver
POSTGRES_PORT=5432

# goose migration runner (make migrate).
GOOSE_DRIVER=postgres
GOOSE_DBSTRING=postgres://gitserver:gitserver@localhost:5432/gitserver?sslmode=disable

# Application Postgres DSN (pgx). Mirrors GOOSE_DBSTRING in dev.
DATABASE_URL=postgres://gitserver:gitserver@localhost:5432/gitserver?sslmode=disable
